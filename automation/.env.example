# Copie este arquivo para automation/.env e preencha os valores.
# automation/.env é local e NUNCA deve ser commitado (contém a service role key).

# Mesma URL do projeto Supabase usado pelo frontend (confira contra VITE_SUPABASE_URL no .env da raiz).
SUPABASE_URL="https://SEU-PROJETO.supabase.co"

# Service role key — Settings > API no painel do Supabase. Só usar aqui, nunca no frontend.
SUPABASE_SERVICE_ROLE_KEY=""

# Pasta do perfil persistente do Chrome (mantém o login da CredPago entre execuções).
# Só usado quando CREDPAGO_STORAGE_STATE_PATH (abaixo) estiver vazio — é o modo local/Windows.
CREDPAGO_PROFILE_DIR="./automation/chrome-profile-credpago"

# Caminho de um arquivo de sessão portátil (gerado por `npm run automation:export-session`).
# Defina isto na VPS/produção; deixe vazio no seu ambiente local (usa o perfil acima).
# CREDPAGO_STORAGE_STATE_PATH="/app/data/credpago-session.json"

# Porta do servidor HTTP só com GET /health (monitoramento/Docker healthcheck).
HEALTH_PORT=3000

# Intervalo (ms) entre verificações de novas consultas pendentes.
AUTOMATION_POLL_INTERVAL_MS=5000

# URL da tela de simulação da CredPago.
CREDPAGO_URL="https://credpago.com/imobiliaria/proposta"

# Se "true", mantém o Chrome aberto após processar (útil para depurar seletores).
AUTOMATION_KEEP_BROWSER_OPEN=false

# Quantas consultas rodam em paralelo (cada uma em sua própria aba do mesmo perfil).
# As consultas excedentes esperam na fila e começam assim que uma vaga libera.
MAX_CONCURRENT_CONSULTAS=3

# Tempo máximo (ms) para UMA consulta antes de ser marcada como erro (não trava as outras).
CONSULTA_TIMEOUT_MS=90000

# Chrome invisível. Requer que o perfil já esteja logado (login manual precisa de janela
# visível) — rode uma vez com HEADLESS=false para logar antes de ativar isto em produção.
HEADLESS=false

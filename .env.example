# Copie este arquivo para .env e preencha os valores do seu projeto Supabase.
# .env é local e NUNCA deve ser commitado (já está no .gitignore).

# --- Variáveis usadas pelo FRONTEND (bundle do navegador via Vite) ---
# Painel Supabase > Project Settings > API.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# URL pública de produção do site — usada para montar os links fixos de
# cadastro da equipe interna NOX (aba Conta NOX: /login/vendedornox etc.).
# Sem isso, o código cai no fallback fixo https://noxfianca.com (nunca
# localhost nem a URL de preview da Vercel) — configure explicitamente em
# cada ambiente (Vercel Production/Preview) mesmo assim.
VITE_PUBLIC_SITE_URL=https://noxfianca.com

# --- Mesmos valores, sem o prefixo VITE_ ---
# Usados pelo código SERVIDOR desta mesma app (SSR do TanStack Start: client.server.ts,
# auth-middleware.ts) — Vite não os expõe ao navegador porque não têm o prefixo VITE_.
# Devem apontar para o MESMO projeto das variáveis VITE_ acima.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=

# Secreta — Painel Supabase > Project Settings > API > service_role.
# Usada apenas em código server-side desta app (client.server.ts). Nunca prefixar com VITE_
# (isso a exporia no bundle do navegador). Nunca commitar o valor real.
SUPABASE_SERVICE_ROLE_KEY=

# Opcional — string de conexão direta ao Postgres (psql, ferramentas externas).
# Não é lida pelo código deste projeto (o app usa a API REST/JS do Supabase, não uma
# conexão direta ao banco). Preencha só se for usar alguma ferramenta externa que precise dela.
# DATABASE_URL=

# Opcional — URL do formulário de proposta da CredPago usada pelo link "Simular no site" do
# frontend. Tem um valor padrão embutido no código; só defina se precisar apontar para outra URL.
# VITE_CREDPAGO_PORTAL_URL=

# PENDENTE — a automação (worker CredPago) ainda roda localmente/fora desta app,
# sem endpoint HTTP próprio. Nenhum código hoje chama isso (grep confirmou zero
# referências). Quando a VPS estiver provisionada com domínio/subdomínio real e
# HTTPS válido, defina aqui e implemente a chamada — nunca use o IP da VPS
# direto nem HTTP sem SSL, e nunca deixe "SUBDOMINIO-DA-VPS" como valor real.
# AUTOMATION_API_URL=https://SUBDOMINIO-DA-VPS.noxfianca.com
# VITE_AUTOMATION_API_URL=https://SUBDOMINIO-DA-VPS.noxfianca.com

# --- Variáveis da automação local (worker separado, roda fora desta app) ---
# Ficam em automation/.env (veja automation/.env.example), não aqui:
#   SUPABASE_SERVICE_ROLE_KEY, CREDPAGO_PROFILE_DIR, HEADLESS, MAX_CONCURRENT_CONSULTAS, etc.

# --- Asaas (gateway de pagamento — Pix/Boleto/Cartão na tela de Pagamento) ---
# Server-side/Supabase Edge Functions apenas — nunca prefixar com VITE_.
ASAAS_API_KEY=
ASAAS_API_BASE_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=
ASAAS_WEBHOOK_URL=
# Em produção, defina explicitamente com o domínio oficial (nunca localhost).
# Só use http://localhost:8080 no seu .env local para desenvolvimento.
APP_BASE_URL=https://noxfianca.com
FRONTEND_URL=https://noxfianca.com
ALLOWED_ORIGINS=https://noxfianca.com

# --- Cakto legado (mantido apenas para histórico/migração) ---
# Painel Cakto > Configurações > API. Server-side apenas — nunca prefixar com VITE_.
CAKTO_CLIENT_ID=COLOCAR_CLIENT_ID_AQUI
CAKTO_CLIENT_SECRET=COLOCAR_CLIENT_SECRET_AQUI
CAKTO_BASE_URL=https://api.cakto.com.br
CAKTO_API_BASE_URL=https://api.cakto.com.br
CAKTO_PRODUCT_ID=COLOCAR_ID_DO_PRODUTO_AQUI
CAKTO_OFFER_ID=COLOCAR_ID_DA_OFERTA_AQUI
# Segredo interno (não vem da Cakto) — gere você mesmo, ex.: `node -e "console.log(crypto.randomUUID())"`.
# Usado para validar o POST do webhook (ver supabase/functions/cakto-webhook).
CAKTO_WEBHOOK_SECRET=CRIAR_UM_SEGREDO_INTERNO_AQUI
APP_URL=https://noxfianca.com

# Pública — mesmo valor de CAKTO_CLIENT_ID acima, mas com prefixo VITE_ para o SDK JS da
# Cakto (antifraude/tokenização) rodar no navegador. Não é secreta (só o client_secret é).
VITE_CAKTO_CLIENT_ID=COLOCAR_CLIENT_ID_AQUI

# --- Resend (e-mail de verificação de cadastro — src/lib/resend.service.ts) ---
# Painel Resend > API Keys. Server-side apenas — nunca prefixar com VITE_.
RESEND_API_KEY=COLOCAR_API_KEY_AQUI
# ID do template "Welcome Nox Fiança" (painel Resend > Templates), não o nome/slug.
RESEND_VERIFY_TEMPLATE_ID=COLOCAR_ID_DO_TEMPLATE_AQUI
# ID do template "Password Reset" (painel Resend > Templates) — usado no e-mail de
# redefinição de senha (src/lib/password-reset.functions.ts). Variáveis esperadas
# pelo template: {{nome}} e {{reset_link}}.
RESEND_RESET_PASSWORD_TEMPLATE_ID=COLOCAR_ID_DO_TEMPLATE_AQUI
RESEND_FROM_EMAIL=NOX Fiança <SEU_REMETENTE@SEU_DOMINIO_VERIFICADO.com.br>
RESEND_REPLY_TO=SEU_EMAIL_DE_CONTATO@SEU_DOMINIO.com.br

# --- SMS transacional de pagamento (Supabase Edge Functions: asaas-create-payment,
# asaas-webhook) --- Nenhum provedor integrado ainda. Sem estas duas variaveis o envio
# de SMS fica desativado (nao simula, so registra no log que falta credencial) —
# preencha com um provedor real (ex.: Zenvia, Twilio) para ativar de verdade.
SMS_API_KEY=
SMS_PROVIDER_URL=

# --- WhatsApp transacional de pagamento (mesmas Edge Functions acima, mais
# process-scheduled-invoice-notifications) --- Integração genérica legada para
# mensagens financeiras. Sem estas duas variáveis esse canal fica desativado.
WHATSAPP_API_KEY=
WHATSAPP_PROVIDER_URL=

# --- WhatsApp pela Z-API após assinatura D4Sign ---
# Credenciais privadas da instância conectada ao WhatsApp Business da NOX.
# Nunca exponha no frontend nem versione valores reais. ZAPI_CLIENT_TOKEN é o
# token de segurança opcional da conta, diferente do token da instância.
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
ZAPI_CLIENT_TOKEN=

# --- Assinatura eletrônica D4Sign (contrato após o primeiro pagamento) ---
# TOKEN_API e CRYPT_KEY ficam em Configurações > Dev(API) da conta D4Sign.
# SAFE_UUID identifica o cofre que recebe os contratos. WEBHOOK_SECRET é um
# segredo aleatório interno incluído na URL de callback e nunca vai ao cliente.
D4SIGN_TOKEN_API=
D4SIGN_CRYPT_KEY=
D4SIGN_SAFE_UUID=9fbb5127-b896-4310-bdca-3933841dfd3a
D4SIGN_WEBHOOK_SECRET=
# Opcional: use somente para substituir a URL padrão da Edge Function.
D4SIGN_WEBHOOK_URL=

# --- Segredo do cron diario de lembretes (process-scheduled-invoice-
# notifications) --- gere voce mesmo (ex.: node -e "console.log(crypto.randomUUID())"),
# configure o MESMO valor aqui, nas secrets da Edge Function (painel Supabase)
# e no Supabase Vault (nome "cron_notifications_secret", ver migration
# 20260714000020_schedule_invoice_reminders.sql) para o pg_cron conseguir
# chamar a function autenticado.
CRON_NOTIFICATIONS_SECRET=CRIAR_UM_SEGREDO_INTERNO_AQUI

# --- Marketing Ads (server-side / Supabase Edge Functions) ---
# Meta Marketing API. Nunca prefixar com VITE_.
META_MARKETING_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PIXEL_ID=
META_GRAPH_API_VERSION=v23.0

# Google Ads API. Nunca prefixar com VITE_.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_MANAGER_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v19

# Copie este arquivo para .env e preencha os valores do seu projeto Supabase.
# .env é local e NUNCA deve ser commitado (já está no .gitignore).

# --- Variáveis usadas pelo FRONTEND (bundle do navegador via Vite) ---
# Painel Supabase > Project Settings > API.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- Mesmos valores, sem o prefixo VITE_ ---
# Usados pelo código SERVIDOR desta mesma app (SSR do TanStack Start: client.server.ts,
# auth-middleware.ts) — Vite não os expõe ao navegador porque não têm o prefixo VITE_.
# Devem apontar para o MESMO projeto das variáveis VITE_ acima.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=

# Secreta — Painel Supabase > Project Settings > API > service_role.
# Usada apenas em código server-side desta app (client.server.ts). Nunca prefixar com VITE_
# (isso a exporia no bundle do navegador). Nunca commitar o valor real.
SUPABASE_SERVICE_ROLE_KEY=

# Opcional — string de conexão direta ao Postgres (psql, ferramentas externas).
# Não é lida pelo código deste projeto (o app usa a API REST/JS do Supabase, não uma
# conexão direta ao banco). Preencha só se for usar alguma ferramenta externa que precise dela.
# DATABASE_URL=

# Opcional — URL do formulário de proposta da CredPago usada pelo link "Simular no site" do
# frontend. Tem um valor padrão embutido no código; só defina se precisar apontar para outra URL.
# VITE_CREDPAGO_PORTAL_URL=

# --- Variáveis da automação local (worker separado, roda fora desta app) ---
# Ficam em automation/.env (veja automation/.env.example), não aqui:
#   SUPABASE_SERVICE_ROLE_KEY, CREDPAGO_PROFILE_DIR, HEADLESS, MAX_CONCURRENT_CONSULTAS, etc.

# --- Cakto (gateway de pagamento — Pix/Boleto/Cartão na tela de Pagamento) ---
# Painel Cakto > Configurações > API. Server-side apenas — nunca prefixar com VITE_.
CAKTO_CLIENT_ID=COLOCAR_CLIENT_ID_AQUI
CAKTO_CLIENT_SECRET=COLOCAR_CLIENT_SECRET_AQUI
CAKTO_BASE_URL=https://api.cakto.com.br
CAKTO_PRODUCT_ID=COLOCAR_ID_DO_PRODUTO_AQUI
CAKTO_OFFER_ID=COLOCAR_ID_DA_OFERTA_AQUI
# Segredo interno (não vem da Cakto) — gere você mesmo, ex.: `node -e "console.log(crypto.randomUUID())"`.
# Usado para validar o POST do webhook (ver supabase/functions/cakto-webhook).
CAKTO_WEBHOOK_SECRET=CRIAR_UM_SEGREDO_INTERNO_AQUI
APP_URL=URL_PUBLICA_DO_SITE

# Pública — mesmo valor de CAKTO_CLIENT_ID acima, mas com prefixo VITE_ para o SDK JS da
# Cakto (antifraude/tokenização) rodar no navegador. Não é secreta (só o client_secret é).
VITE_CAKTO_CLIENT_ID=COLOCAR_CLIENT_ID_AQUI

# --- Resend (e-mail de verificação de cadastro — src/lib/resend.service.ts) ---
# Painel Resend > API Keys. Server-side apenas — nunca prefixar com VITE_.
RESEND_API_KEY=COLOCAR_API_KEY_AQUI
# ID do template "Welcome Nox Fiança" (painel Resend > Templates), não o nome/slug.
RESEND_VERIFY_TEMPLATE_ID=COLOCAR_ID_DO_TEMPLATE_AQUI
RESEND_FROM_EMAIL=NOX Fiança <SEU_REMETENTE@SEU_DOMINIO_VERIFICADO.com.br>
RESEND_REPLY_TO=SEU_EMAIL_DE_CONTATO@SEU_DOMINIO.com.br

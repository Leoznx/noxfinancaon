# Copie este arquivo para .env e preencha os valores do seu projeto Supabase.
# .env é local e NUNCA deve ser commitado (já está no .gitignore).

# --- Variáveis usadas pelo FRONTEND (bundle do navegador via Vite) ---
# Painel Supabase > Project Settings > API.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- Mesmos valores, sem o prefixo VITE_ ---
# Usados pelo código SERVIDOR desta mesma app (SSR do TanStack Start: client.server.ts,
# auth-middleware.ts) — Vite não os expõe ao navegador porque não têm o prefixo VITE_.
# Devem apontar para o MESMO projeto das variáveis VITE_ acima.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=

# Secreta — Painel Supabase > Project Settings > API > service_role.
# Usada apenas em código server-side desta app (client.server.ts). Nunca prefixar com VITE_
# (isso a exporia no bundle do navegador). Nunca commitar o valor real.
SUPABASE_SERVICE_ROLE_KEY=

# Opcional — string de conexão direta ao Postgres (psql, ferramentas externas).
# Não é lida pelo código deste projeto (o app usa a API REST/JS do Supabase, não uma
# conexão direta ao banco). Preencha só se for usar alguma ferramenta externa que precise dela.
# DATABASE_URL=

# Opcional — URL do formulário de proposta da CredPago usada pelo link "Simular no site" do
# frontend. Tem um valor padrão embutido no código; só defina se precisar apontar para outra URL.
# VITE_CREDPAGO_PORTAL_URL=

# --- Variáveis da automação local (worker separado, roda fora desta app) ---
# Ficam em automation/.env (veja automation/.env.example), não aqui:
#   SUPABASE_SERVICE_ROLE_KEY, CREDPAGO_PROFILE_DIR, HEADLESS, MAX_CONCURRENT_CONSULTAS, etc.
